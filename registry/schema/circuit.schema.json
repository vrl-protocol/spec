{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VRL Circuit Descriptor Schema",
  "description": "JSON Schema for validating VRL Circuit Descriptors (vrl/circuit/1.0)",
  "type": "object",
  "required": [
    "circuit_id",
    "spec_version",
    "circuit_hash",
    "domain",
    "name",
    "version",
    "description",
    "input_schema",
    "output_schema",
    "proof_systems",
    "constraint_count",
    "certification_tier",
    "published_at",
    "author",
    "license"
  ],
  "properties": {
    "circuit_id": {
      "type": "string",
      "description": "Human-readable circuit identifier in format '<domain>/<name>@<version>'",
      "pattern": "^[a-z0-9]+/[a-z0-9\\-]+@\\d+\\.\\d+\\.\\d+$",
      "examples": ["trade/import-landed-cost@1.0.0", "healthcare/clinical-decision-support@1.0.0"]
    },
    "spec_version": {
      "type": "string",
      "description": "VRL specification version this circuit conforms to",
      "enum": ["vrl/circuit/1.0"],
      "examples": ["vrl/circuit/1.0"]
    },
    "circuit_hash": {
      "type": "string",
      "description": "SHA-256 hash of the canonical circuit descriptor (immutable)",
      "pattern": "^[a-f0-9]{64}$",
      "examples": ["2f1a5c8b3e7d9a4b6c2e1f8a5d9c3b7e8f1a5c2d9e3f4a7b1c8e5d2a9f6b3"]
    },
    "domain": {
      "type": "string",
      "description": "Logical domain/category for the circuit",
      "enum": ["trade", "healthcare", "finance", "general"],
      "examples": ["trade", "finance"]
    },
    "name": {
      "type": "string",
      "description": "Short name of the circuit",
      "pattern": "^[a-z0-9\\-]+$",
      "examples": ["import-landed-cost", "credit-risk-scoring"]
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the circuit",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0", "2.0.0"]
    },
    "description": {
      "type": "string",
      "description": "One-line description of the circuit",
      "minLength": 10,
      "maxLength": 200
    },
    "long_description": {
      "type": "string",
      "description": "Detailed multi-line description of the circuit, its purpose, and use cases",
      "minLength": 50
    },
    "input_schema": {
      "type": "object",
      "description": "Schema for circuit inputs (private and public)",
      "properties": {
        "private": {
          "type": "array",
          "description": "Array of private input definitions (witness values)",
          "items": {
            "$ref": "#/definitions/input_field"
          }
        },
        "public": {
          "type": "array",
          "description": "Array of public input definitions (instance columns)",
          "items": {
            "$ref": "#/definitions/input_field"
          }
        }
      },
      "required": ["private", "public"],
      "additionalProperties": false
    },
    "output_schema": {
      "type": "object",
      "description": "Schema for circuit outputs",
      "properties": {
        "public": {
          "type": "array",
          "description": "Array of public output definitions",
          "items": {
            "$ref": "#/definitions/output_field"
          }
        }
      },
      "required": ["public"],
      "additionalProperties": false
    },
    "proof_systems": {
      "type": "array",
      "description": "Array of supported proof systems",
      "items": {
        "type": "string",
        "enum": [
          "plonk-halo2-pasta",
          "plonk-halo2-bn254",
          "groth16-bn254",
          "stark",
          "zk-ml",
          "tee-intel-tdx",
          "tee-amd-sev-snp",
          "tee-aws-nitro",
          "sha256-deterministic",
          "api-hash-binding"
        ]
      },
      "minItems": 1,
      "examples": [["plonk-halo2-pasta"], ["tee-intel-tdx", "tee-amd-sev-snp"]]
    },
    "constraint_count": {
      "type": "integer",
      "description": "Number of arithmetic constraints in the circuit",
      "minimum": 1,
      "examples": [8, 12, 10]
    },
    "instance_layout": {
      "type": "array",
      "description": "Names of instance columns in order",
      "items": {
        "type": "string"
      }
    },
    "dataset_dependencies": {
      "type": "array",
      "description": "Array of external datasets required by this circuit",
      "items": {
        "$ref": "#/definitions/dataset_dependency"
      },
      "default": []
    },
    "certification_tier": {
      "type": "string",
      "description": "Certification level of the circuit",
      "enum": ["EXPERIMENTAL", "REVIEWED", "CERTIFIED"],
      "examples": ["REVIEWED", "CERTIFIED"]
    },
    "certified_by": {
      "type": "string",
      "description": "Name of entity that certified the circuit (for REVIEWED and CERTIFIED tiers)",
      "examples": ["VRL Maintainers", "Trail of Bits"]
    },
    "certification_date": {
      "type": "string",
      "description": "ISO 8601 timestamp of certification",
      "format": "date-time"
    },
    "audit_report": {
      "type": "string",
      "description": "URL to public audit report (required for CERTIFIED circuits)",
      "format": "uri"
    },
    "regulatory_approval": {
      "type": "string",
      "description": "Regulatory approvals or certifications",
      "examples": ["FDA Software as Medical Device compliant (SaMD)"]
    },
    "published_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of initial publication",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of last update",
      "format": "date-time"
    },
    "author": {
      "type": "string",
      "description": "Circuit author(s) or working group",
      "examples": ["VRL Trade Working Group", "John Doe"]
    },
    "author_email": {
      "type": "string",
      "description": "Email contact for the author",
      "format": "email"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier for the circuit descriptor",
      "enum": [
        "Apache-2.0",
        "MIT",
        "GPL-3.0",
        "CC0-1.0",
        "CC-BY-4.0"
      ],
      "examples": ["Apache-2.0", "CC0-1.0"]
    },
    "repository": {
      "type": "string",
      "description": "URL to source repository",
      "format": "uri"
    },
    "tags": {
      "type": "array",
      "description": "Array of tags for categorization and discovery",
      "items": {
        "type": "string"
      },
      "examples": [["trade", "customs", "tariff"], ["healthcare", "clinical"]]
    },
    "compliance_frameworks": {
      "type": "array",
      "description": "Compliance frameworks this circuit addresses",
      "items": {
        "type": "string",
        "enum": [
          "EU_AI_ACT",
          "HIPAA",
          "SOX",
          "GDPR",
          "FCRA",
          "ECOA",
          "FDA_SAMD",
          "CBP_ACE",
          "BASEL_III",
          "EAR",
          "ITAR",
          "OFAC"
        ]
      },
      "default": []
    },
    "security_notes": {
      "type": "string",
      "description": "Security considerations and limitations"
    },
    "performance_notes": {
      "type": "string",
      "description": "Performance characteristics and benchmarks"
    },
    "changelog": {
      "type": "array",
      "description": "Version history and changes",
      "items": {
        "$ref": "#/definitions/changelog_entry"
      }
    },
    "deprecated": {
      "type": "boolean",
      "description": "Whether this circuit is deprecated",
      "default": false
    }
  },
  "additionalProperties": false,
  "definitions": {
    "input_field": {
      "type": "object",
      "required": ["name", "type", "description"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "type": {
          "type": "string",
          "enum": ["integer", "string", "boolean", "array", "object"]
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "output_field": {
      "type": "object",
      "required": ["name", "type", "description"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "type": {
          "type": "string",
          "enum": ["integer", "string", "boolean", "array", "object"]
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "dataset_dependency": {
      "type": "object",
      "required": ["dataset_id", "min_version"],
      "properties": {
        "dataset_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+/[a-z0-9\\-]+$",
          "examples": ["cbp/hts-tariff-rules", "fda/drug-interactions"]
        },
        "min_version": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)*(\\.\\d+)?$",
          "examples": ["2026.1.0", "2026.1"]
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "changelog_entry": {
      "type": "object",
      "required": ["version", "date", "changes"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "changes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
